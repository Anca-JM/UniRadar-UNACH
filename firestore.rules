rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    match /gastro_items/{docId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.keys().hasOnly(['name','vendor','location','price','category','available','updatedAt'])
        && request.resource.data.name is string
        && request.resource.data.vendor is string
        && request.resource.data.location is string
        && request.resource.data.category is string
        && request.resource.data.price is number
        && request.resource.data.price >= 0
        && request.resource.data.price <= 20
        && request.resource.data.available is bool;
      allow delete: if signedIn();
    }

    match /aca_events/{docId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.keys().hasOnly(['title','organizer','location','date','time','description','updatedAt'])
        && request.resource.data.title is string
        && request.resource.data.organizer is string
        && request.resource.data.location is string
        && request.resource.data.date is string
        && request.resource.data.time is string
        && request.resource.data.description is string;
      allow delete: if signedIn();
    }

    match /{document=**} {
      allow read: if false;
      allow write: if false;
    }
  }
}
